# === Firebase Client (public) ===
NEXT_PUBLIC_FIREBASE_API_KEY=
# In production with redirect auth on a custom domain, use your app host,
# e.g. intelesalud.medicalcore.app
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === Firebase Admin (server-only, JSON string) ===
FIREBASE_SERVICE_ACCOUNT_KEY=

# === Database ===
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/intelesalud?schema=public

# === Security ===
IP_HASH_SECRET=change_me_to_random_64_char_string

# === App URLs ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Optional Google Calendar / Meet automation ===
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_SERVICE_ACCOUNT_KEY=
GOOGLE_CALENDAR_IMPERSONATE_USER=
GOOGLE_CALENDAR_TIME_ZONE=America/Lima
