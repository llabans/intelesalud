# VPS access
VPS_IP=44.235.121.195
VPS_USER=admin
# Windows absolute path to your SSH private key
VPS_KEY_PATH=C:\Users\MAGNUS\.ssh\lightsail.pem

# App deploy target
VPS_TARGET_DIR=/var/www/intelesalud
VPS_DOMAIN=intelesalud.medicalcore.app
VPS_APP_PORT=3004
VPS_APP_USER=admin
VPS_APP_GROUP=admin
VPS_SERVICE_NAME=intelesalud
VPS_NGINX_SITE_NAME=intelesalud

# SSL - reuse existing wildcard cert (*.medicalcore.app) on VPS
VPS_SSL_MODE=cloudflare_origin
VPS_SSL_CERT_PATH=/etc/ssl/cloudflare/medicalcore/medicalcore-origin.pem
VPS_SSL_KEY_PATH=/etc/ssl/cloudflare/medicalcore/medicalcore-origin.key

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/intelesalud?schema=public

# Firebase Auth
NEXT_PUBLIC_FIREBASE_API_KEY=
# Use the app host in production, e.g. intelesalud.medicalcore.app
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_AUTH_PROXY_TARGET=

# Security
IP_HASH_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://intelesalud.medicalcore.app

# Optional Google Calendar / Meet automation
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_SERVICE_ACCOUNT_KEY=
GOOGLE_CALENDAR_IMPERSONATE_USER=
GOOGLE_CALENDAR_TIME_ZONE=America/Lima
